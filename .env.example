# --- Database ---
# Local default uses SQLite (no server needed). For Postgres, change the
# datasource provider in prisma/schema.prisma to "postgresql" and set a URL like:
#   postgresql://user:password@localhost:5432/unswap
DATABASE_URL="file:./dev.db"

# --- Auth (NextAuth v5) ---
# Generate with: openssl rand -base64 32  (or: npx auth secret)
AUTH_SECRET="change-me-to-a-long-random-string"
# Public base URL used in emails / callbacks.
AUTH_URL="http://localhost:3000"

# --- Email (Resend) ---
# Optional locally: without a key, emails are logged to the console instead.
RESEND_API_KEY=""
EMAIL_FROM="UnSwap <onboarding@resend.dev>"
